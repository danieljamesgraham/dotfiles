" Syntax highlighting
syntax on

" 4 bit color scheme
set t_Co=16
highlight LineNr ctermfg=Grey
highlight NonText ctermfg=DarkGrey
highlight StatusLine ctermfg=Grey

" Status bar
set laststatus=2

" Line numbers
set nu rnu

" Wrap text
set wrap
set linebreak

" Ruler
set ruler

" Autoindent
set autoindent
